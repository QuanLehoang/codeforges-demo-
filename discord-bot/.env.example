DISCORD_TOKEN=bot_token_discord
DISCORD_CHANNEL_ID=id_channel_thong_ke
DISCORD_PAYMENT_CHANNEL_ID=id_channel_thanh_toan_rieng

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_supabase

# Bot checks paid orders every 60 seconds.
POLL_SECONDS=60

# false = do not spam old paid orders on first run.
# true = announce existing paid orders that are not in data/announced-orders.json.
ANNOUNCE_EXISTING=false

# true = send a sales summary when the bot starts.
SEND_STARTUP_SUMMARY=true
